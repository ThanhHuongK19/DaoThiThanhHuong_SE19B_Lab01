@model BusinessObjects.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1 class="text-danger">Delete Product</h1>
<h3>Are you sure you want to delete this product?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Product Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ProductName)</dd>

        <dt class="col-sm-3">Unit Price</dt>
        <dd class="col-sm-9">@string.Format("{0:C}", Model.UnitPrice)</dd>

        <dt class="col-sm-3">Units In Stock</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.UnitsInStock)</dd>

        <dt class="col-sm-3">Category Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Category.CategoryName)</dd>
    </dl>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="ProductId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>